===pc9 SP ====

Program - 9: Store and retrieve simple Key-value Pairs (e.g. username) using Shared
Preferences.
Code :
import 'package:flutter/material.dart';
import 'package:shared_preferences/shared_preferences.dart';
void main() {
runApp(MyApp());
}
class MyApp extends StatelessWidget {
@override
Widget build(BuildContext context) {
return MaterialApp(
title: 'SharedPrefs Demo',
theme: ThemeData(primarySwatch: Colors.blue),
home: StorageScreen(),
);
}
}
class StorageScreen extends StatefulWidget {
@override
_StorageScreenState createState() => _StorageScreenState();
}
class _StorageScreenState extends State<StorageScreen> {
final TextEditingController _controller = TextEditingController();
String _storedValue = 'Nothing stored yet';
@override
void initState() {
super.initState();
_loadData();
}
@override
void dispose() {
_controller.dispose();
super.dispose();
}
Future<void> _loadData() async {
final prefs = await SharedPreferences.getInstance();
setState(() {
_storedValue = prefs.getString('username') ?? 'Nothing stored yet';
});
}
Future<void> _saveData() async {
final prefs = await SharedPreferences.getInstance();
await prefs.setString('username', _controller.text);
_controller.clear();
await _loadData();
}
Future<void> _clearData() async {
final prefs = await SharedPreferences.getInstance();
await prefs.remove('username');
await _loadData();
}
@override
Widget build(BuildContext context) {
return Scaffold(
appBar: AppBar(title: Text('SharedPreferences Demo')),
body: Padding(
padding: const EdgeInsets.all(16.0),
child: Column(
crossAxisAlignment: CrossAxisAlignment.stretch,
children: [
TextField(
controller: _controller,
decoration: InputDecoration(
labelText: 'Enter username',
border: OutlineInputBorder(),
),
),
SizedBox(height: 16),
ElevatedButton(onPressed: _saveData, child: Text('Save')),
SizedBox(height: 16),
ElevatedButton(
onPressed: _clearData,
style: ElevatedButton.styleFrom(backgroundColor: Colors.red),
child: Text('Clear Storage'),
),
SizedBox(height: 32),
Text(
'Stored Value:',
style: TextStyle(fontWeight: FontWeight.bold),
),
SizedBox(height: 8),
Text(_storedValue, style: TextStyle(fontSize: 18)),
],
),
),
);
}
}

